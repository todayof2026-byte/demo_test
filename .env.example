# ==============================================================================
# automationexercise.com E2E - environment template
# ==============================================================================
# Copy this file to `.env` and fill in real values. The .env file is gitignored.

# --- Test profile -------------------------------------------------------------
# Which storefront profile to target. Currently supported: default
PROFILE=default

# --- Credentials --------------------------------------------------------------
# Live login is performed once per session and the auth state is reused
# from auth/storage_state.json (see src/flows/auth_flow.py).
SITE_EMAIL=your-test-account@example.com
SITE_PASSWORD=replace-me

# --- Browser & runtime --------------------------------------------------------
# Run with a visible browser window (true/false). Default: false (headless).
HEADED=false

# Slow down each Playwright action by N ms (useful for debugging). 0 = off.
SLOW_MO=0

# Default per-action timeout in ms.
ACTION_TIMEOUT_MS=15000

# Default navigation timeout in ms.
NAVIGATION_TIMEOUT_MS=30000

# --- Reporting ----------------------------------------------------------------
# Capture Playwright trace: 'on', 'off', 'retain-on-failure', 'on-first-retry'
TRACE_MODE=retain-on-failure
